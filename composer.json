{
    "name": "bigeweb/bigeweb-framework",
    "version": "1.4.7",
    "description": "This MVC framework provides a structured approach to developing web applications by separating the application's concerns into three distinct components: model, view, and controller. This separation of concerns promotes code organization, maintainability, and scalability, making it easier to manage and extend the application over time",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "dompdf/dompdf": "dev-master",
        "symfony/mailer": "6.4.x-dev",
        "phpmailer/phpmailer": "dev-master",
        "phpoffice/phpspreadsheet": "dev-master",
        "symfony/http-client": "6.4.x-dev",
        "guzzlehttp/guzzle": "7.10",
        "php-http/guzzle7-adapter": "1.x-dev",
        "ext-curl": "*",
        "ext-pdo": "*",
        "symfony/var-dumper": "6.4.x-dev",
        "nesbot/carbon": "^3.0@dev",
        "limahost/homepage": "^1.0",
        "limahost/dashboard": "^1.0",
        "limahost/adminauth": "^1.0",
        "webroot/email": "^1.0",
        "limahost/menu": "^1.0",
        "limahost/page": "^1.0",
        "webroot/ticket": "^1.0",
        "limahost/setting": "^1.0",
        "limahost/catalog": "^1.0",
        "bigeweb/inventory": "^1.0",
        "bigeweb/acl": "^1.0",
        "bigeweb/supplier": "^1.0",
        "ext-intl": "*",
        "limahost/systemopt": "^1.0",
        "limahost/ads": "^1.0",
        "limahost/cart": "^1.0",
        "limahost/courier": "^1.0",
        "limahost/myaccount": "^1.0",
        "webroot/gateway": "dev-main",
        "jomweb/billplz": "*",
        "limahost/authentication": "^1.0",
        "limahost/order": "^1.0"
    },
    "repositories" : [
        {"type" :  "vcs",
        "url" :  "https://github.com/delyn112/bigeweb-framework"},
        { "type": "path",   "url": "Packages/Base/Acl"  },
        { "type": "path",   "url": "Packages/Base/Email"  },
        { "type": "path",   "url": "Packages/Frontend/Homepage"  },
        { "type": "path",   "url": "Packages/Admin/AdminAuthentication"  },
        { "type": "path",   "url": "Packages/Admin/Menu"},
        { "type": "path",   "url": "Packages/Admin/Pages"},
        { "type": "path",   "url": "Packages/Admin/Ticket"},
        { "type": "path",   "url": "Packages/Admin/Dashboard"},
        { "type": "path",   "url": "Packages/Admin/Configurations"},
        { "type": "path",   "url": "Packages/Admin/Catalogs"},
        { "type": "path",   "url": "Packages/Admin/Inventory"},
        { "type": "path",   "url": "Packages/Admin/Suppliers"},
        { "type": "path",   "url": "Packages/Admin/Themeoption"},
        { "type": "path",   "url": "Packages/Admin/Ads"},
        { "type": "path",   "url": "Packages/Frontend/Cart"},
        { "type": "path",   "url": "Packages/Admin/Courier"},
        { "type": "path",   "url": "Packages/Frontend/MyAccountManager"},
        { "type": "path",   "url": "Packages/Admin/Gateway"},
        { "type": "path",   "url": "Packages/Admin/Order"}
    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Bigeweb\\App\\": "app/",
            "illuminate\\Support\\": "vendor/bigeweb/framework/",
            "config\\": "config",
            "Database\\Migrations\\" : "database/migrations/",
            "Database\\Seeders\\" : "database/seeders/"
        },
        "files" : [
            "config/utils.php"
        ]
    },
    "authors": [
        {
            "name": "Bigeweb Solution",
            "email": "developer@bigeweb.com"
        }
    ],
    "minimum-stability": "dev",
    "config": {
        "platform": {
            "php": "8.1"
        },
        "ignore-platform-reqs": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
